<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
{% if inline_plotly %}
<script>{{ plotly_js }}</script>
{% else %}
<script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
{% endif %}
<style>
{% include "components/style_inline.html.j2" ignore missing %}
</style>
</head>
<body>
<div class="layout">
  {% include "components/toc.html.j2" %}
  <main class="main">
    {% block header %}
    <div class="report-header">
      <h1>{{ title }}</h1>
      <p>{{ subtitle }}</p>
      {% for badge in badges %}
      <span class="badge">{{ badge }}</span>
      {% endfor %}
    </div>
    {% endblock %}

    {% for section in sections %}
    {% include "section.html.j2" %}
    {% endfor %}

    <footer class="report-footer">
      <p>Generated by <strong>DissectML {{ version }}</strong></p>
    </footer>
  </main>
</div>
<script>
{% include "components/script_inline.html.j2" ignore missing %}
</script>
</body>
</html>
